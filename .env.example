# --- Database (Postgres + pgvector) ---
# Local dev (matches docker-compose.yml). In production use Neon / Vercel Postgres.
DATABASE_URL="postgresql://psych:psych@localhost:5432/psych?schema=public"

# --- LLM provider ---
# "openrouter" (default, works when deployed) or "claude-cli" (local dev only).
LLM_PROVIDER="openrouter"

# OpenRouter (required when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_APP_URL="http://localhost:3000"
OPENROUTER_APP_NAME="Personal Psychologist"

# Claude Code CLI (used when LLM_PROVIDER=claude-cli). Local only — not available on Vercel.
CLAUDE_CLI_MODEL="sonnet"

# --- Text-to-speech (optional) ---
# ElevenLabs cloud voice. When ELEVENLABS_API_KEY is set, the coach speaks with
# this voice; otherwise it falls back to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=""
# Default voice: https://elevenlabs.io/app/voice-library?voiceId=RDWdsTU6N02BFftbIEAp
ELEVENLABS_VOICE_ID="RDWdsTU6N02BFftbIEAp"
ELEVENLABS_MODEL="eleven_turbo_v2_5"

# --- Retrieval (RAG) ---
# Local embedding model id (transformers.js). 384-dim; must match the vector(N) column.
EMBEDDING_MODEL="Xenova/bge-small-en-v1.5"
# Number of chunks retrieved per turn.
RAG_TOP_K="6"

# --- Ingestion: OpenAlex sources (harvard / stanford / journals / psychology) ---
# Your email enables OpenAlex's faster, more reliable "polite pool".
OPENALEX_MAILTO=""
# Set to "1" to also best-effort fetch open-access PDFs during ingestion (slower).
OPENALEX_FULLTEXT="0"

# --- Rate Limiting & Abuse Prevention (Phase 3) ---
# Enable/disable rate limiting globally. Set to "false" to disable in development.
RATE_LIMIT_ENABLED="true"
# Maximum messages per session per minute (prevents spamming in a single session).
RATE_LIMIT_MESSAGE_PER_MIN="20"
# Maximum session creations per IP per hour (prevents session creation spam).
RATE_LIMIT_SESSION_PER_HOUR="10"
# Maximum requests per IP per hour (prevents DDoS-style attacks).
RATE_LIMIT_IP_PER_HOUR="100"

# --- Sentry Monitoring & Error Tracking (Phase 2) ---
# Server-side Sentry DSN (error tracking and performance monitoring)
# Get this from https://sentry.io/settings/[org]/projects/[project]/keys/
SENTRY_DSN=""
# Public client-side Sentry DSN (must be NEXT_PUBLIC_ for browser)
NEXT_PUBLIC_SENTRY_DSN=""
# Environment: development, staging, or production
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"
# Release version (typically git commit hash or semver)
SENTRY_RELEASE=""
NEXT_PUBLIC_SENTRY_RELEASE=""
# Performance monitoring sample rate (0.0 to 1.0)
# Dev: 1.0 (100%) for detailed tracing, Production: 0.1 (10%) to reduce noise
SENTRY_TRACES_SAMPLE_RATE="1.0"
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="1.0"

# --- Authentication (Phase 5) ---
# JWT signing keys (RS256 asymmetric). Generate with:
# openssl genrsa -out private.pem 2048
# openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# Secret for session cookies and CSRF protection
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Base URL for auth redirects
NEXTAUTH_URL="http://localhost:3000"

# Email Service (Resend - free tier)
EMAIL_SERVICE="resend"
RESEND_API_KEY=""
EMAIL_FROM="noreply@psychologist.local"

# OAuth2 Google
OAUTH_GOOGLE_CLIENT_ID=""
OAUTH_GOOGLE_CLIENT_SECRET=""
OAUTH_GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# OAuth2 GitHub
OAUTH_GITHUB_CLIENT_ID=""
OAUTH_GITHUB_CLIENT_SECRET=""
OAUTH_GITHUB_REDIRECT_URI="http://localhost:3000/api/auth/github/callback"

# --- User Profiles & Privacy (Phase 6) ---
# Base64-encoded 32-byte AES-256 encryption key for PII encryption
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# REQUIRED in production; optional in development (uses fallback key)
ENCRYPTION_KEY=""
