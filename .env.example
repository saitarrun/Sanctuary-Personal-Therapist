# --- Database (Postgres + pgvector) ---
# Local dev (matches docker-compose.yml). In production use Neon / Vercel Postgres.
DATABASE_URL="postgresql://psych:psych@localhost:5432/psych?schema=public"

# --- LLM provider ---
# "openrouter" (default, works when deployed) or "claude-cli" (local dev only).
LLM_PROVIDER="openrouter"

# OpenRouter (required when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="anthropic/claude-sonnet-4.6"
OPENROUTER_APP_URL="http://localhost:3000"
OPENROUTER_APP_NAME="Personal Psychologist"

# Claude Code CLI (used when LLM_PROVIDER=claude-cli). Local only — not available on Vercel.
CLAUDE_CLI_MODEL="sonnet"

# --- Text-to-speech (optional) ---
# ElevenLabs cloud voice. When ELEVENLABS_API_KEY is set, the coach speaks with
# this voice; otherwise it falls back to the browser's built-in speech synthesis.
ELEVENLABS_API_KEY=""
# Default voice: https://elevenlabs.io/app/voice-library?voiceId=RDWdsTU6N02BFftbIEAp
ELEVENLABS_VOICE_ID="RDWdsTU6N02BFftbIEAp"
ELEVENLABS_MODEL="eleven_turbo_v2_5"

# --- Retrieval (RAG) ---
# Local embedding model id (transformers.js). 384-dim; must match the vector(N) column.
EMBEDDING_MODEL="Xenova/bge-small-en-v1.5"
# Number of chunks retrieved per turn.
RAG_TOP_K="6"

# --- Ingestion: OpenAlex sources (harvard / stanford / journals / psychology) ---
# Your email enables OpenAlex's faster, more reliable "polite pool".
OPENALEX_MAILTO=""
# Set to "1" to also best-effort fetch open-access PDFs during ingestion (slower).
OPENALEX_FULLTEXT="0"
